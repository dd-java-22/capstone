<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

<androidx.constraintlayout.widget.ConstraintLayout
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:padding="24dp">

  <!-- ========================= -->
  <!--      USER AVATAR          -->
  <!-- ========================= -->
  <ImageView
    android:id="@+id/avatarImage"
    android:layout_width="140dp"
    android:layout_height="140dp"
    android:layout_marginTop="24dp"
    android:src="@drawable/ic_default_avatar"
    android:scaleType="centerCrop"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:contentDescription="@string/user_avatar" />

  <!-- Edit avatar button (pencil) -->
  <ImageButton
    android:id="@+id/editAvatarButton"
    android:layout_width="36dp"
    android:layout_height="36dp"
    android:src="@drawable/ic_edit"
    android:background="@android:color/transparent"
    android:contentDescription="@string/edit_profile_picture"
    app:layout_constraintBottom_toBottomOf="@id/avatarImage"
    app:layout_constraintEnd_toEndOf="@id/avatarImage"
    android:padding="4dp" />

  <!-- ========================= -->
  <!--     DISPLAY NAME          -->
  <!-- ========================= -->
  <TextView
    android:id="@+id/displayNameLabel"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:text="@string/display_name_label"
    android:textSize="14sp"
    android:textStyle="bold"
    app:layout_constraintTop_toBottomOf="@id/avatarImage"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="32dp" />

  <EditText
    android:id="@+id/displayNameInput"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:hint="@string/display_name_hint"
    android:inputType="textPersonName"
    android:textSize="16sp"
    app:layout_constraintTop_toBottomOf="@id/displayNameLabel"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="8dp"
    android:autofillHints="name" />

  <!-- ========================= -->
  <!--          EMAIL            -->
  <!-- ========================= -->
  <TextView
    android:id="@+id/emailLabel"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:text="@string/email_label"
    android:textSize="14sp"
    android:textStyle="bold"
    app:layout_constraintTop_toBottomOf="@id/displayNameInput"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="24dp" />

  <EditText
    android:id="@+id/emailInput"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:hint="@string/email_hint"
    android:inputType="textEmailAddress"
    android:textSize="16sp"
    app:layout_constraintTop_toBottomOf="@id/emailLabel"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="8dp"
    android:autofillHints="emailAddress" />

  <!-- ========================= -->
  <!--     USERNAME (Display)    -->
  <!-- ========================= -->
  <TextView
    android:id="@+id/usernameLabel"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:text="@string/username_label"
    android:textSize="14sp"
    android:textStyle="bold"
    app:layout_constraintTop_toBottomOf="@id/emailInput"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="24dp" />

  <TextView
    android:id="@+id/usernameValue"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:text="@string/username_placeholder"
    android:textSize="16sp"
    app:layout_constraintTop_toBottomOf="@id/usernameLabel"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="8dp"
    android:textColor="?android:attr/textColorSecondary" />

  <!-- ========================= -->
  <!--     EMAIL (Display)       -->
  <!-- ========================= -->
  <TextView
    android:id="@+id/emailDisplayLabel"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:text="@string/email_current_label"
    android:textSize="14sp"
    android:textStyle="bold"
    app:layout_constraintTop_toBottomOf="@id/usernameValue"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="24dp" />

  <TextView
    android:id="@+id/emailValue"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:text="@string/email_placeholder"
    android:textSize="16sp"
    app:layout_constraintTop_toBottomOf="@id/emailDisplayLabel"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="8dp"
    android:textColor="?android:attr/textColorSecondary" />

  <TextView
    android:id="@+id/authorityLevelValue"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:text="Authority Level: Loading..."
    android:textSize="16sp"
    app:layout_constraintTop_toBottomOf="@id/emailValue"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="24dp"
    android:textColor="?android:attr/textColorSecondary" />

  <TextView
    android:id="@+id/issueReportCountValue"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:text="Issue Reports: Loading..."
    android:textSize="16sp"
    app:layout_constraintTop_toBottomOf="@id/authorityLevelValue"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="8dp"
    android:textColor="?android:attr/textColorSecondary" />

  <!-- ========================= -->
  <!--      SAVE BUTTON          -->
  <!-- ========================= -->
  <Button
    android:id="@+id/saveProfileButton"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:text="@string/save_profile"
    android:textSize="16sp"
    app:layout_constraintTop_toBottomOf="@id/issueReportCountValue"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginTop="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
