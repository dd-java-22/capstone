<?xml version="1.0" encoding="utf-8"?>
<navigation
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/nav_graph"
  app:startDestination="@id/login_fragment">

  <fragment
    android:id="@+id/login_fragment"
    android:name="edu.cnm.deepdive.seesomethingabq.controller.LoginFragment"
    android:label="@string/login_fragment_label"
    tools:layout="@layout/fragment_login">

    <action
      android:id="@+id/navigate_to_main_fragment"
      app:destination="@id/main_fragment"
      app:popUpTo="@id/login_fragment"
      app:popUpToInclusive="true"/>

  </fragment>

  <fragment
    android:id="@+id/main_fragment"
    android:name="edu.cnm.deepdive.seesomethingabq.controller.MainFragment"
    android:label="@string/main_fragment_label"
    tools:layout="@layout/fragment_main">

    <action
      android:id="@+id/navigate_to_login_fragment"
      app:destination="@id/login_fragment"
      app:popUpTo="@id/login_fragment"
      app:popUpToInclusive="true"/>

  </fragment>

</navigation>