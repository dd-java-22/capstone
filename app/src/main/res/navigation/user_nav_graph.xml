<navigation
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/user_nav_graph"
  app:startDestination="@id/user_login_fragment">

  <fragment
    android:id="@+id/user_login_fragment"
    android:name="edu.cnm.deepdive.seesomethingabq.controller.UserLoginFragment"
    android:label="User Login"
    tools:layout="@layout/fragment_user_login">

    <action
      android:id="@+id/navigate_to_user_dashboard_fragment"
      app:destination="@id/user_dashboard_fragment"
      app:popUpTo="@id/user_login_fragment"
      app:popUpToInclusive="true"/>

  </fragment>

  <fragment
    android:id="@+id/user_dashboard_fragment"
    android:name="edu.cnm.deepdive.seesomethingabq.controller.UserDashboardFragment"
    android:label="User Dashboard"
    tools:layout="@layout/fragment_user_dashboard">

    <action
      android:id="@+id/navigate_to_create_issue_report_fragment"
      app:destination="@id/create_issue_report_fragment"/>

    <action
      android:id="@+id/navigate_to_report_detail_fragment"
      app:destination="@id/report_detail_fragment" />

    <action
      android:id="@+id/navigate_to_user_profile"
      app:destination="@id/user_profile_fragment" />

  </fragment>

  <fragment
    android:id="@+id/create_issue_report_fragment"
    android:name="edu.cnm.deepdive.seesomethingabq.controller.CreateIssueReportFragment"
    android:label="Create Issue Report"
    tools:layout="@layout/fragment_create_issue_report">

    <action
      android:id="@+id/navigate_to_user_dashboard_fragment"
      app:destination="@id/user_dashboard_fragment"
      app:popUpTo="@id/user_dashboard_fragment"
      app:popUpToInclusive="true"/>

  </fragment>


  <fragment
    android:id="@+id/report_detail_fragment"
    android:name="edu.cnm.deepdive.seesomethingabq.controller.ReportDetailFragment"
    android:label="Report Details"
    tools:layout="@layout/fragment_report_detail">

    <argument
      android:name="reportId"
      app:argType="string" />
  </fragment>

  <fragment
    android:id="@+id/user_profile_fragment"
    android:name="edu.cnm.deepdive.seesomethingabq.controller.UserProfileFragment"
    android:label="Profile"
    tools:layout="@layout/fragment_user_profile" />

</navigation>
